<MudDatePicker
    Date="Date"
    DateChanged="DateChanged"
    Placeholder="@PlaceHolder"
    Editable="true"
    Variant="Variant"
    Margin="@Mud.Margin"
    Mask="@(new DateMask(Mask))"
    HelperText="@Mask"
    DateFormat="@Mask" />

@code {
    [Parameter]
    public DateTime? Date { get; set; }

    [Parameter]
    public string? PlaceHolder { get; set; }

    [Parameter]
    public EventCallback<DateTime?> DateChanged { get; set; }

    [Parameter]
    public Variant Variant { get; set; } = Mud.Variant;

    [Parameter]
    public string Mask { get; set; } = "yyyy/MM/dd";
}
