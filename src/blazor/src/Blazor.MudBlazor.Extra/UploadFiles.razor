<div class="mb-3">

    <div class="d-flex align-items-center">
        <MudFileUpload T="IBrowserFile" Accept="@Accept" FilesChanged="FilesChangedAsync">
            <SelectedTemplate />
        </MudFileUpload>

        <u><a href="@TemplateUrl" target="_blank" class="ml-3">template</a></u>
    </div>

    @if (Files.Count > 0)
    {
        @*<MudText Typo="@Typo.h6">@Files.Count() File@(Files.Count() == 1 ? "" : "s"):</MudText>*@
        <MudList T="string">
            @foreach (var file in Files)
            {
                <MudListItem Icon="@Icons.Material.Filled.AttachFile" @key="@file" Dense="true">
                    @file.Name <code>@file.Size bytes</code>
                </MudListItem>
            }
        </MudList>

        <div class="mt-2">
            <Button Label="Import" Color="AppColor.Primary" OnClick="OnImport" />
            <Button Label="Clear" OnClick="ClearAsync" Color="default" />
        </div>
    }
</div>

@code {
    [Parameter]
    public IList<IBrowserFile> Files { get; set; } = new List<IBrowserFile>();

    [Parameter]
    public EventCallback OnImport { get; set; }

    [Parameter]
    public EventCallback<IList<IBrowserFile>> FilesChanged { get; set; }

    [Parameter]
    public string TemplateUrl { get; set; } = null!;

    [Parameter]
    public string Accept { get; set; } = ".xlsx";

    private Task FilesChangedAsync(IBrowserFile file)
    {
        Files.Clear();
        Files.Add(file);
        //TODO upload the files to the server

        return NotifyFilesChanged();
    }

    private Task ClearAsync()
    {
        Files.Clear();

        return NotifyFilesChanged();
    }

    private Task NotifyFilesChanged() => FilesChanged.InvokeAsync(Files);
}
